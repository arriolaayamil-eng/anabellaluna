# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/anabellaluna

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_32chars_min

# ── Admin credentials (synced on startup) ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ── 2FA ───────────────────────────────────────────────────────────────────────
TWO_FACTOR_ENCRYPTION_KEY=your_32_byte_hex_key_here
TWO_FACTOR_ISSUER=AnabellaLuna
TWO_FACTOR_TEMP_TOKEN_SECRET=change_me_tfa_temp_secret

# ── Redis (optional — system runs without it) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Providers ─────────────────────────────────────────────────────────────
# 32-byte hex key for encrypting AI API keys in MongoDB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_ENCRYPTION_KEY=your_64_char_hex_key_here_generate_with_crypto

# ── Meta Ads ──────────────────────────────────────────────────────────────────
# Key for encrypting Meta Ads access token in MongoDB (can reuse AI_ENCRYPTION_KEY)
META_ENCRYPTION_KEY=your_64_char_hex_key_here_generate_with_crypto

# ── Storage (MinIO) ───────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anabella
MINIO_USE_SSL=false

# ── Cloudinary (optional) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Social Auth (public frontend) ────────────────────────────────────────────
GOOGLE_LOGIN_CLIENT_ID=
FACEBOOK_APP_ID=

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/crm/integrations/google/callback

# ── Push Notifications ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@anabellaluna.com.ar

# ── npm install instructions ──────────────────────────────────────────────────
# After adding AI features, run in /backend:
#   npm install socket.io @socket.io/redis-adapter ioredis openai @anthropic-ai/sdk
#
# In /admin and /agents:
#   npm install socket.io-client
