MONGODB_URI=mongodb://<username>:<password>@host:27017/<database>?retryWrites=true&w=majority
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
JWT_SECRET=please-change-this-secret
PORT=4000
NODE_ENV=development

# Optional: enable verbose DB logs (true/false)
DB_VERBOSE=false
PORT=4000

# MongoDB connection string. Replace <username>,<password>,<host>,<port>,<database> with your values.
# Example (Mongo Atlas):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://<username>:<password>@host:27017/<database>

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT secret used to sign tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

STORAGE_PROVIDER=minio

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anabella
MINIO_BUCKET_CRM=anabellaluna-crm
MINIO_BUCKET_ERP=anabellaluna-erp
MINIO_BUCKET_WEB=anabellaluna-web
MINIO_REGION=

# Google Calendar OAuth (per-agent integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add GOOGLE_OAUTH_REDIRECT_URI to "Authorized redirect URIs"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/crm/integrations/google-calendar/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3001/crm/integraciones?googleCalendar=connected
DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires

# Web Push (VAPID keys) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@anabellaluna.com

# Admin credentials (used by seed.js)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# NOTE: Google Maps API key lives in the frontend env files, NOT here:
#   admin/.env         → REACT_APP_GOOGLE_MAPS_API_KEY=your_key
#   agents/.env        → REACT_APP_GOOGLE_MAPS_API_KEY=your_key
#   frontend/.env      → VITE_GOOGLE_MAPS_API_KEY=your_key

# ── Mercado Libre integration ──────────────────────────────────────────────────
# Master AES-256 encryption key for ML credentials stored in MongoDB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is the ONLY ML variable that lives in .env — all other ML credentials
# (CLIENT_ID, CLIENT_SECRET, REDIRECT_URI, WEBHOOK_URL) are configured from
# the admin panel (ERP → Integraciones → Mercado Libre) and stored encrypted in DB.
ML_ENCRYPTION_KEY=

# ── OpenClaw — Gateway local (proveedor AI principal) ─────────────────────────
# OpenClaw corre en tu máquina y expone una API OpenAI-compatible.
# Descargá OpenClaw en https://openclaw.ai
# Con OPENCLAW_BASE_URL seteado, se usa automáticamente como provider por defecto.
# Puerto 18789 = gateway principal (UI + API). Requiere token de auth configurado en openclaw.json
OPENCLAW_BASE_URL=http://127.0.0.1:18789
# OPENCLAW_TOKEN=   (token de auth — ver gateway.auth.token en ~/.openclaw/openclaw.json)
# OPENCLAW_MODEL=openrouter/openai/gpt-4o-mini   (ver agents.defaults.model.primary en ~/.openclaw/openclaw.json)

# ── AI Copilot (fallback providers) ──────────────────────────────────────────
# Anthropic API key (fallback si OpenClaw no está disponible)
ANTHROPIC_API_KEY=
# Model to use (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514